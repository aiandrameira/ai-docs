{
    "name": "cli",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/cli/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/esbuild:esbuild",
            "outputs": ["{options.outputPath}"],
            "dependsOn": ["^build", "web:build"],
            "options": {
                "outputPath": "dist/libs/cli",
                "main": "libs/cli/src/index.ts",
                "additionalEntryPoints": ["libs/cli/src/config.ts"],
                "tsConfig": "libs/cli/tsconfig.lib.json",
                "assets": [
                    "libs/cli/*.md",
                    { "glob": "theme.css", "input": "libs/cli/src/assets", "output": "assets" },
                    { "glob": "**/*", "input": "dist/apps/web/server", "output": "web/server" },
                    { "glob": "**/*", "input": "dist/apps/web/browser", "output": "web/browser" }
                ],
                "bundle": true,
                "thirdParty": true,
                "platform": "node",
                "format": ["cjs"],
                "declaration": true,
                "generatePackageJson": false,
                "includeIgnoredAssetFiles": true
            }
        }
    }
}
